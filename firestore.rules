rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if document belongs to the logged-in user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users collection rules
    match /users/{userId} {
      // Users can only read and write their own profile information
      allow read, write: if isOwner(userId);
    }

    // 2. Products collection rules
    match /products/{productId} {
      // Anyone can browse products (public read)
      allow read: if true;
      
      // Clients cannot write to products. Only Admin SDK (server-side / seed script) can write.
      allow write: if false;
    }

    // 3. Orders collection rules
    match /orders/{orderId} {
      // Customers can create orders if they are logged in and the order belongs to them
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Customers can read or update (e.g., cancel) their own orders
      // Admin (authenticated) can read and update all orders
      // NOTE: In production, restrict admin operations to specific Admin UIDs or phone numbers
      allow read, update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        // OPTIONAL: Add admin UIDs here for stricter security, e.g.:
        // request.auth.uid in ['ADMIN_UID_1', 'ADMIN_UID_2']
        // For development simplicity, any authenticated user can read/update all orders
        true
      );
      
      // Clients cannot delete orders
      allow delete: if false;
    }
  }
}
